# BrickForge Development Environment
# Copy to .env and fill in values — NEVER commit .env to git

# ── Renderer ────────────────────────────────────────────────────────
VITE_APP_NAME=BrickForge
VITE_APP_VERSION=0.1.0-alpha

# ── Sidecar ─────────────────────────────────────────────────────────
BF_SIDECAR_PORT=8741
BF_ENV=development

# ── AI ──────────────────────────────────────────────────────────────
# Stored in OS keychain (safeStorage) in production
# Only needed in .env for local sidecar dev
OPENAI_API_KEY=sk-...

# ── External APIs ────────────────────────────────────────────────────
# Stored via Electron safeStorage in production; .env for dev only
REBRICKABLE_API_KEY=
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN=
BRICKLINK_TOKEN_SECRET=
